# Conan 2 profile — Linux x86-64, Clang 18, C++20
# Used by CI and local builds.  Override build_type on the command line:
#   conan install . --profile conan/profiles/linux-clang18 --build=missing \
#                   -s build_type=Debug

[settings]
os=Linux
arch=x86_64
compiler=clang
compiler.version=18
compiler.libcxx=libstdc++11
compiler.cppstd=20

[conf]
# Ensures both VirtualBuildEnv (package source builds) and CMakeToolchain
# (our project's conan_toolchain.cmake) use the correct clang binaries.
tools.build:compiler_executables={"c": "clang-18", "cpp": "clang++-18"}
